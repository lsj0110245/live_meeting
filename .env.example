# Database
POSTGRES_USER=lm_postgres
POSTGRES_PASSWORD=change_this_to_secure_password
POSTGRES_DB=live_meeting
# From outside Docker, use localhost:15432. From inside, use db:5432.
DATABASE_URL=postgresql://lm_postgres:change_this_to_secure_password@db:5432/live_meeting

# JWT Authentication
# Generate a new key: openssl rand -hex 32
SECRET_KEY=change_this_to_generated_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# Application Settings
APP_NAME=LiveMeeting
DEBUG=true
# Frontend & Backend both served on 8001
CORS_ORIGINS=http://localhost:8001,http://localhost:3000

# File Upload Settings
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=mp3,wav,m4a,mp4,webm,avi,mov

# STT Settings (Faster-Whisper Only Mode)
STT_ENGINE=faster-whisper
# DEEPGRAM_API_KEY=your_deepgram_key_if_used
# DEEPGRAM_MODEL=nova-2

# Faster-Whisper Settings
STT_LANGUAGE=ko-KR
STT_MODEL_SIZE=deepdml/faster-whisper-large-v3-turbo-ct2
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16

# LLM Settings (Ollama)
LLM_MODEL=exaone3.5:7.8b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
OLLAMA_BASE_URL=http://llm:11434

# Storage
STORAGE_TYPE=local

# LangSmith (Monitoring)
# Variable names synced with backend/app/core/config.py
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=LiveMeeting

# External Services
HUGGING_FACE_TOKEN=your_huggingface_token
# OPENAI_API_KEY=your_openai_key
# GOOGLE_API_KEY=your_google_key

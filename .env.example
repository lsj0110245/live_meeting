# Database
POSTGRES_USER=lm_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=live_meeting
DATABASE_URL=postgresql://lm_user:your_secure_password_here@db:5432/live_meeting

# AWS Credentials (Nova-2 STT)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# LLM API (Choose one)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT Authentication
SECRET_KEY=your_random_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
APP_NAME=LiveMeeting
DEBUG=true
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# File Upload Settings
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=mp3,wav,m4a,mp4,webm,avi,mov

# STT Settings
STT_LANGUAGE=ko-KR
# or en-US, ja-JP, etc.

# LLM Settings
LLM_MODEL=gpt-4
# or claude-3-opus-20240229
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# Storage (local or s3)
STORAGE_TYPE=local
# If using S3:
# STORAGE_TYPE=s3
# S3_BUCKET_NAME=your-bucket-name
# S3_REGION=us-east-1
